# acps-cli 敏感凭证配置示例
# 复制为 .env 后填入实际值（.env 已加入 .gitignore，不提交到版本库）

# ── reg-cli 用户端凭证 ──────────────────────────────────────────────────────────
REGISTRY_USER_USERNAME=
REGISTRY_USER_PASSWORD=
# 可选：显示名称与所属组织（auto-register 时使用）
# REGISTRY_USER_NAME=
# REGISTRY_USER_ORG_NAME=

# ── reg-admin-cli 管理员凭证 ────────────────────────────────────────────────────
# REGISTRY_ADMIN_USERNAME=admin
# REGISTRY_ADMIN_PASSWORD=

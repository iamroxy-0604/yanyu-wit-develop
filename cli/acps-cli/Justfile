set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

project_name := "acps-cli"
dev_infra_script := "../acps-infra/dev-infra/dev-infra.sh"
config_file := "acps-cli.toml"

default:
    @just help

help:
        @echo "acps-cli Just 命令"
        @echo ""
        @echo "用法："
        @echo "  just dev [action] [args...]"
        @echo "  just test [action] [args...]"
        @echo "  just qa [action] [args...]"
        @echo "  just infra [action] [args...]"
        @echo "  just doctor"
        @echo "  just prep [action] [args...]"
        @echo ""
        @echo "dev：开发联调环境准备"
        @echo "  bootstrap        建立开发环境（默认动作：infra up + prep env + prep sync + prep hooks）"
        @echo ""
        @echo "test：测试入口"
        @echo "  bootstrap        建立测试环境（infra up + prep env + prep sync + prep hooks）"
        @echo "  unit             运行单元测试；支持透传 pytest 参数"
        @echo "  coverage         运行单元测试覆盖率门禁（fail-under=70）"
        @echo "  integration      运行集成测试；默认本地地址缺服务时由夹具自动托管"
        @echo "  e2e              运行端到端测试；默认本地地址缺服务时由夹具自动托管"
        @echo "  all              依次执行 unit -> integration -> e2e"
        @echo ""
        @echo "qa：代码质量入口"
        @echo "  fmt              执行 ruff format ."
        @echo "  type             执行 mypy acps_cli/"
        @echo "  fix              执行 format + ruff check --fix"
        @echo "  precommit        执行 pre-commit run --all-files"
        @echo "  all              依次执行 fix -> precommit"
        @echo ""
        @echo "infra：共享依赖管理"
        @echo "  status [service...] [--format=tsv]   查看共享依赖状态"
        @echo "  up [service...]                      启动共享依赖，默认 postgres"
        @echo "  down                                 停止共享依赖"
        @echo "  wait [service...]                    等待共享依赖就绪"
        @echo "  logs [service...] [--follow]         查看共享依赖日志"
        @echo "  reset [service...] [--volumes --yes] 修复性重建共享依赖"
        @echo "  doctor                               检查共享 infra 环境"
        @echo ""
        @echo "doctor：联调环境检查"
        @echo "  检查 python3 / uv / just / acps-cli.toml / uv sync 状态 / 默认目标服务可达性"
        @echo ""
        @echo "prep：维护与局部修复动作"
        @echo "  env      缺失时根据 .env.example 生成 .env"
        @echo "  sync     执行 uv sync"
        @echo "  hooks    安装/更新 pre-commit 与 commit-msg hooks"
        @echo ""
        @echo "常用示例："
        @echo "  just dev bootstrap"
        @echo "  just test bootstrap"
        @echo "  just test"
        @echo "  just qa"

infra action='status' *args:
    @{{dev_infra_script}} {{action}} {{args}}

doctor:
    #!/usr/bin/env bash
    set -eu -o pipefail
    tmpfile="$(mktemp)"
    trap 'rm -f "${tmpfile}"' EXIT
    issues=0

    get_config_value() {
        local section="$1"
        local key="$2"

        python3 -c 'exec("from pathlib import Path\nimport re\nimport sys\nconfig_path, section_name, key_name = sys.argv[1:4]\ntext = Path(config_path).read_text(encoding=\"utf-8\")\nsection_pattern = rf\"(?ms)^\\[{re.escape(section_name)}\\]\\s*(.*?)(?=^\\[|\\Z)\"\nsection_match = re.search(section_pattern, text)\nif section_match is None:\n    raise SystemExit(1)\nbody = section_match.group(1)\nkey_pattern = rf\"(?m)^\\s*{re.escape(key_name)}\\s*=\\s*\\\"([^\\\"]+)\\\"\"\nkey_match = re.search(key_pattern, body)\nif key_match is None:\n    raise SystemExit(1)\nprint(key_match.group(1))")' "{{config_file}}" "${section}" "${key}"
    }

    resolve_service_base_url() {
        local env_name="$1"
        local section="$2"
        local fallback="$3"
        local env_value="${!env_name:-}"

        if [[ -n "${env_value}" ]]; then
            printf '%s\n' "${env_value}"
            return
        fi

        if config_value="$(get_config_value "${section}" "server_base_url" 2>/dev/null)"; then
            printf '%s\n' "${config_value}"
            return
        fi

        printf '%s\n' "${fallback}"
    }

    derive_health_url() {
        local base_url="$1"

        python3 -c 'from urllib.parse import urlsplit; import sys; parts = urlsplit(sys.argv[1]); sys.stdout.write(f"{parts.scheme}://{parts.netloc}/health\n") if (parts.scheme and parts.netloc) else sys.exit(1)' "${base_url}"
    }

    check_health_url() {
        local service_name="$1"
        local health_url="$2"

        if python3 -c 'exec("import sys\nimport urllib.error\nimport urllib.request\nurl = sys.argv[1]\ntry:\n    with urllib.request.urlopen(url, timeout=5) as response:\n        raise SystemExit(0 if 200 <= response.status < 400 else 1)\nexcept urllib.error.HTTPError as exc:\n    raise SystemExit(0 if 200 <= exc.code < 400 else 1)\nexcept Exception:\n    raise SystemExit(1)")' "${health_url}"
        then
            echo "[INFO]  ${service_name} 可达：${health_url}"
        else
            echo "[ERROR] ${service_name} 不可达：${health_url}" >&2
            print_service_start_hint "${service_name}"
            issues=$((issues + 1))
        fi
    }

    print_service_start_hint() {
        local service_name="$1"

        case "${service_name}" in
            registry-server)
                echo "[HINT] 启动命令：cd ../registry-server && APP_ENV=development CA_SERVER_MOCK=false just app bootstrap && APP_ENV=development CA_SERVER_MOCK=false just app" >&2
                ;;
            ca-server)
                echo "[HINT] 启动命令：cd ../ca-server && APP_ENV=development REGISTRY_SERVER_MOCK=false just app bootstrap && APP_ENV=development REGISTRY_SERVER_MOCK=false just app" >&2
                ;;
            discovery-server)
                echo "[HINT] 启动命令：cd ../discovery-server && just app bootstrap && just app" >&2
                ;;
        esac

        echo "[HINT] 若当前不是本地联调环境，请检查 acps-cli.toml 或 REGISTRY_URL / CA_URL / DISCO_URL 配置。" >&2
    }

    if ! command -v python3 >/dev/null 2>&1; then
        echo "[ERROR] 未找到 python3，请先安装 Python 3.10+。" >&2
        issues=$((issues + 1))
    elif ! python3 -c 'import sys; raise SystemExit(0 if sys.version_info >= (3, 10) else 1)'; then
        echo "[ERROR] python3 版本不满足 pyproject.toml 要求（需要 >=3.10）。" >&2
        issues=$((issues + 1))
    fi

    if ! command -v uv >/dev/null 2>&1; then
        echo "[ERROR] 未找到 uv，请先安装 uv。" >&2
        issues=$((issues + 1))
    elif ! uv sync --check --locked >"${tmpfile}" 2>&1; then
        echo "[ERROR] Python 环境未同步或缺失，请先执行 just prep sync。" >&2
        cat "${tmpfile}" >&2
        issues=$((issues + 1))
    fi

    if ! command -v just >/dev/null 2>&1; then
        echo "[ERROR] 未找到 just，请先安装 just。" >&2
        issues=$((issues + 1))
    fi

    if [[ ! -f "{{config_file}}" ]]; then
        echo "[ERROR] 未找到默认配置文件：{{config_file}}" >&2
        issues=$((issues + 1))
    fi

    if [[ ! -f .env ]]; then
        echo "[WARN]  未找到 .env；登录相关命令可能不可用，可按需执行 just prep env。" >&2
    fi

    if [[ "${issues}" -eq 0 ]]; then
        registry_base_url="$(resolve_service_base_url REGISTRY_URL registry http://localhost:9001/api/v1)"
        ca_base_url="$(resolve_service_base_url CA_URL ca http://localhost:9003/acps-atr-v2)"
        disco_base_url="$(resolve_service_base_url DISCO_URL discovery http://localhost:9005)"

        if registry_health_url="$(derive_health_url "${registry_base_url}" 2>/dev/null)"; then
            check_health_url "registry-server" "${registry_health_url}"
        else
            echo "[ERROR] 无法从 registry 配置推导健康检查地址：${registry_base_url}" >&2
            echo "[HINT] 请检查 acps-cli.toml [registry].server_base_url 或 REGISTRY_URL。" >&2
            print_service_start_hint "registry-server"
            issues=$((issues + 1))
        fi

        if ca_health_url="$(derive_health_url "${ca_base_url}" 2>/dev/null)"; then
            check_health_url "ca-server" "${ca_health_url}"
        else
            echo "[ERROR] 无法从 ca 配置推导健康检查地址：${ca_base_url}" >&2
            echo "[HINT] 请检查 acps-cli.toml [ca].server_base_url 或 CA_URL。" >&2
            print_service_start_hint "ca-server"
            issues=$((issues + 1))
        fi

        if disco_health_url="$(derive_health_url "${disco_base_url}" 2>/dev/null)"; then
            check_health_url "discovery-server" "${disco_health_url}"
        else
            echo "[ERROR] 无法从 discovery 配置推导健康检查地址：${disco_base_url}" >&2
            echo "[HINT] 请检查 acps-cli.toml [discovery].server_base_url 或 DISCO_URL。" >&2
            print_service_start_hint "discovery-server"
            issues=$((issues + 1))
        fi
    fi

    if [[ "${issues}" -gt 0 ]]; then
        exit 1
    fi

    echo "[INFO]  doctor checks passed for {{project_name}}"

_bootstrap_common:
    @just infra up postgres
    @just infra up redis
    @just infra up rabbitmq
    @just prep env
    @just prep sync
    @just prep hooks

prep action='help' *args:
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{action}}"

    print_help() {
        echo "prep 维护动作："
        echo "  just prep env    缺失时根据 .env.example 生成 .env"
        echo "  just prep sync   执行 uv sync"
        echo "  just prep hooks  安装/更新 pre-commit 与 commit-msg hooks"
    }

    install_git_hooks() {
        if ! git rev-parse --git-dir >/dev/null 2>&1; then
            echo "[WARN]  当前目录不是 Git 仓库，跳过 Git hooks 安装。"
            return
        fi

        uv run pre-commit install --hook-type pre-commit --hook-type commit-msg
        echo "[INFO]  已安装或更新 pre-commit / commit-msg hooks。"
    }

    case "${action}" in
        help|"")
            print_help
            ;;
        env)
            if [[ -f .env ]]; then
                echo "[INFO]  .env 已存在，跳过生成。"
            elif [[ -f .env.example ]]; then
                cp .env.example .env
                echo "[INFO]  已根据 .env.example 生成 .env。"
            else
                echo "[ERROR] 未找到 .env.example，无法生成 .env。" >&2
                exit 1
            fi
            ;;
        sync)
            UV_MANAGED_PYTHON=1 uv python install 3.14
            UV_MANAGED_PYTHON=1 uv sync --python 3.14 --managed-python
            ;;
        hooks)
            install_git_hooks
            ;;
        *)
            echo "[ERROR] 未知 prep action: ${action}" >&2
            exit 2
            ;;
    esac

dev action='bootstrap':
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{action}}"

    case "${action}" in
        bootstrap|"")
            just _bootstrap_common
            ;;
        *)
            echo "[ERROR] 未知 dev action: ${action}" >&2
            exit 2
            ;;
    esac

test action='all' *args:
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{action}}"
    args_string="{{args}}"

    requested_args=()
    if [[ -n "${args_string}" ]]; then
        read -r -a requested_args <<< "${args_string}"
    fi

    run_scoped_pytest() {
        local default_path="$1"
        shift
        local selection=("$@")

        if [[ "${#selection[@]}" -eq 0 ]]; then
            uv run pytest "${default_path}"
            return
        fi

        if [[ "${selection[0]}" == -* ]]; then
            uv run pytest "${default_path}" "${selection[@]}"
            return
        fi

        uv run pytest "${selection[@]}"
    }

    run_requested_tests() {
        local default_path="$1"

        if [[ "${#requested_args[@]}" -gt 0 ]]; then
            run_scoped_pytest "${default_path}" "${requested_args[@]}"
            return
        fi

        run_scoped_pytest "${default_path}"
    }

    case "${action}" in
        bootstrap)
            just _bootstrap_common
            ;;
        unit)
            run_requested_tests tests/unit/
            ;;
        coverage)
            if [[ "${#requested_args[@]}" -gt 0 ]]; then
                uv run pytest tests/unit/ "${requested_args[@]}" --cov=acps_cli --cov-report=term-missing --cov-fail-under=70
            else
                uv run pytest tests/unit/ --cov=acps_cli --cov-report=term-missing --cov-fail-under=70
            fi
            ;;
        integration)
            run_requested_tests tests/integration/
            ;;
        e2e)
            run_requested_tests tests/e2e/
            ;;
        all)
            just test unit
            just test integration
            just test e2e
            ;;
        *)
            echo "[ERROR] 未知 test action: ${action}" >&2
            exit 2
            ;;
    esac

qa action='all' *args:
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{action}}"

    case "${action}" in
        all)
            just qa fix
            just qa precommit
            ;;
        fmt)
            uv run ruff format .
            ;;
        type)
            uv run mypy acps_cli/
            ;;
        fix)
            uv run ruff format .
            uv run ruff check . --fix
            ;;
        precommit)
            uv run pre-commit run --all-files
            ;;
        *)
            echo "[ERROR] 未知 qa action: ${action}" >&2
            exit 2
            ;;
    esac